# Helm — fastlane lane for iOS release via CI (no local Xcode needed).
# Run by .github/workflows/ios.yml in "release" mode. Needs these env vars (GitHub secrets):
#   APPSTORE_KEY_ID, APPSTORE_ISSUER_ID, APPSTORE_PRIVATE_KEY  (App Store Connect API key .p8 contents)
#   APPLE_TEAM_ID                                              (your 10-char Developer Team ID)

default_platform(:ios)

APP_ID = "capital.treetop.helm"

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_PRIVATE_KEY"]
    )

    # Next build number = one above the latest already on TestFlight
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ) + 1
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: next_build)

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Automatic",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
