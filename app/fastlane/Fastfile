# HelpBnk — fastlane lane for iOS release via CI (no local Xcode needed).
# Run by .github/workflows/ios.yml in "release" mode. Needs these GitHub secrets:
#   APPSTORE_KEY_ID, APPSTORE_ISSUER_ID, APPSTORE_PRIVATE_KEY  (App Store Connect API key; key is base64)
#   APPLE_TEAM_ID                                              (10-char Developer Team ID)
#   MATCH_PASSWORD, MATCH_GIT_URL, MATCH_GIT_TOKEN             (signing storage via fastlane match)

require "base64"

default_platform(:ios)

APP_ID = "capital.treetop.helm"
PROFILE = "match AppStore #{APP_ID}"

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_PRIVATE_KEY"],
      is_key_content_base64: true
    )

    # Create/fetch the distribution certificate + App Store profile (no devices needed),
    # stored encrypted in the private MATCH_GIT_URL repo. First run creates them.
    match(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: api_key,
      readonly: false,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}")
    )

    # Next build number = one above the latest already on TestFlight
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ) + 1
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: next_build)

    # Point the project at the match profile (manual signing — distribution needs no device)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE,
      bundle_identifier: APP_ID
    )

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: { APP_ID => PROFILE }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
