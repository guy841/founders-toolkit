# Helm — fastlane lanes for iOS release via CI (no local Xcode needed).
# Enable once Apple enrolment + the App Store Connect API key + signing secrets exist
# (see APP_STORE.md ▸ "Cloud build"). Run with: bundle exec fastlane beta

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # App Store Connect API key from CI secrets
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    # Bump the build number to the next TestFlight build
    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: latest_testflight_build_number(api_key: api_key, app_identifier: "capital.treetop.helm") + 1
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
